---
import BaseLayout from "../layouts/BaseLayout.astro";

const items = [
  { label: "Email", value: "hello@example.com", href: "mailto:hello@example.com" },
  { label: "Affiliation", value: "Imperial College London", href: null },
  { label: "GitHub", value: "@alemicheli", href: "https://github.com/alemicheli" },
  { label: "Scholar", value: "Google Scholar", href: "https://scholar.google.com/" },
];
---

<BaseLayout title="Contact — Alessandro Micheli">
  <section class="mx-auto max-w-3xl px-6 pt-36 pb-24">
    <div class="mb-4 flex items-center gap-4">
      <span class="block h-px w-10 bg-white/15"></span>
      <span class="coord-label">INDEX · CONTACT</span>
    </div>

    <h1 class="display text-balance text-5xl leading-[1.05] md:text-7xl">
      Get in touch.
    </h1>

    <p class="mt-6 text-lg leading-8" style="color: var(--color-paper-dim)">
      Open to research collaborations, PhD/Postdoc discussions, and conversations with
      industry partners on machine learning systems for science and high-stakes domains.
    </p>

    <div class="hairline mt-12 rounded-md">
      {items.map((item, i) => (
        <div class={`grid grid-cols-[130px_1fr] items-baseline gap-4 px-6 py-5 md:px-8 ${i < items.length - 1 ? "border-b border-white/5" : ""}`}>
          <span class="coord-label">{item.label.toUpperCase()}</span>
          {item.href ? (
            <a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer" class="text-lg" style="color: var(--color-paper)">
              {item.value}
            </a>
          ) : (
            <span class="text-lg" style="color: var(--color-paper)">{item.value}</span>
          )}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
