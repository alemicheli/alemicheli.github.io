---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact — Alessandro Micheli">
  <section class="mx-auto max-w-3xl px-6 pt-32 pb-24">
    <p class="mb-3 text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">
      Contact
    </p>

    <h1 class="text-5xl font-semibold tracking-tight md:text-7xl">
      Get in touch.
    </h1>

    <p class="mt-7 text-lg leading-8 text-slate-300">
      I am open to research collaborations, PhD/Postdoc discussions, and conversations
      with industry partners on uncertainty-aware AI for high-stakes domains.
    </p>

    <div class="glass mt-12 grid gap-4 rounded-3xl p-8 md:grid-cols-2">
      <div>
        <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Email</p>
        <a href="mailto:hello@example.com" class="mt-2 block text-lg font-semibold text-white hover:text-cyan-300">
          hello@example.com
        </a>
      </div>
      <div>
        <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Affiliation</p>
        <p class="mt-2 text-lg font-semibold text-white">Imperial College London</p>
      </div>
      <div>
        <p class="text-sm uppercase tracking-[0.3em] text-slate-400">GitHub</p>
        <a href="https://github.com/alemicheli" target="_blank" rel="noreferrer" class="mt-2 block text-lg font-semibold text-white hover:text-cyan-300">
          @alemicheli
        </a>
      </div>
      <div>
        <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Scholar</p>
        <a href="https://scholar.google.com/" target="_blank" rel="noreferrer" class="mt-2 block text-lg font-semibold text-white hover:text-cyan-300">
          Google Scholar
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
