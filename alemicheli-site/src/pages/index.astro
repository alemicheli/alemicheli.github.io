---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import FeaturedTalk from "../components/FeaturedTalk.astro";
import BioSection from "../components/BioSection.astro";
import { getCollection } from "astro:content";

const publications = await getCollection("publications");
const recent = publications
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout>
  <Hero />

  <section class="mx-auto max-w-6xl px-6 pb-28 pt-20">
    <div class="mb-10 flex items-center gap-4">
      <span class="block h-px w-10 bg-white/15"></span>
      <span class="coord-label">Recent work</span>
    </div>

    <div class="hairline rounded-md">
      {recent.map((pub, i) => (
        <article class={`grid gap-4 px-6 py-7 md:grid-cols-[110px_1fr_auto] md:items-start md:px-8 md:py-8 ${i < recent.length - 1 ? "border-b border-white/5" : ""}`}>
          <div class="flex flex-col">
            <span class="coord-label">№ {String(i + 1).padStart(2, "0")}</span>
            <span class="mt-2 text-sm" style="color: var(--color-paper-dim)">{pub.data.year}</span>
          </div>

          <div>
            {pub.data.status && (
              <span class="hairline inline-block rounded-sm px-2.5 py-1 font-mono text-[0.7rem] uppercase tracking-[0.18em]" style="color: var(--color-accent); border-color: rgba(122,140,255,0.35)">
                {pub.data.status}
              </span>
            )}

            <h3 class="display mt-4 text-balance text-xl tracking-tight md:text-2xl">
              {pub.data.title}
            </h3>

            <p class="mt-1 text-sm" style="color: var(--color-dim)">
              {pub.data.authors.join(", ")}
            </p>

            {pub.data.description && (
              <p class="mt-4 max-w-2xl leading-7" style="color: var(--color-paper-dim)">
                {pub.data.description}
              </p>
            )}
          </div>

          {pub.data.links.length > 0 && (
            <div class="flex flex-wrap gap-3 md:justify-end">
              {pub.data.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noreferrer"
                  class="hairline hairline-hover rounded-sm px-3 py-1.5 text-xs"
                  style="color: var(--color-paper)"
                >
                  {link.label} ↗
                </a>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </section>

  <FeaturedTalk />

  <BioSection />
</BaseLayout>
