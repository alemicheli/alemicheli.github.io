---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
---

<BaseLayout title={`${frontmatter.title} — Alessandro Micheli`}>
  <section class="mx-auto max-w-3xl px-6 pt-32 pb-20">
    <p class="mb-3 text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">
      Research project
    </p>
    <h1 class="text-4xl font-semibold tracking-tight md:text-6xl">
      {frontmatter.title}
    </h1>
    <p class="mt-5 text-lg leading-8 text-slate-300">
      {frontmatter.summary}
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {frontmatter.tags?.map((tag: string) => (
        <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-300">
          {tag}
        </span>
      ))}
    </div>

    <article class="prose prose-invert mt-12 max-w-none prose-headings:tracking-tight prose-headings:font-semibold prose-p:text-slate-300 prose-p:leading-8 prose-a:text-cyan-300">
      <slot />
    </article>
  </section>
</BaseLayout>
