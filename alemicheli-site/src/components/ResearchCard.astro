---
const { title, description, tags = [], href } = Astro.props;
---

<a
  href={href}
  class="glass group rounded-3xl p-6 transition duration-300 hover:-translate-y-1 hover:border-cyan-300/40"
>
  <div class="mb-8 h-32 rounded-2xl bg-gradient-to-br from-violet-500/20 via-cyan-400/10 to-transparent"></div>

  <h3 class="text-2xl font-semibold tracking-tight">
    {title}
  </h3>

  <p class="mt-4 leading-7 text-slate-300">
    {description}
  </p>

  <div class="mt-6 flex flex-wrap gap-2">
    {tags.map((tag: string) => (
      <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-300">
        {tag}
      </span>
    ))}
  </div>

  <p class="mt-8 text-sm font-semibold text-cyan-300">
    Explore project →
  </p>
</a>
