---
import IntelligenceField from "./IntelligenceField.astro";
---

<section class="relative min-h-[92vh] overflow-hidden">
  <div class="pointer-events-none absolute inset-0">
    <IntelligenceField />
  </div>

  <div class="relative z-10 mx-auto grid min-h-[92vh] max-w-6xl grid-cols-1 px-6 pt-32 pb-20">
    <div class="self-center">
      <p class="coord-label mb-8">Alessandro Micheli — Imperial College London</p>

      <h1 class="display text-balance max-w-5xl text-5xl leading-[1.04] md:text-7xl">
        Designing <span class="text-[var(--color-accent)]">how AI systems learn.</span>
      </h1>

      <p class="mt-8 max-w-2xl text-lg leading-9 md:text-xl"
         style="color: var(--color-paper-dim)">
        I am an AI researcher at Imperial College London working across
        generative modelling, geometric learning, probabilistic methods, and AI for science.
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a
          href="/cv.pdf"
          class="hairline hairline-hover px-5 py-2.5 text-sm font-medium tracking-wide"
          style="color: var(--color-paper)"
        >
          Curriculum vitae
        </a>
        <a
          href="mailto:a.micheli19@imperial.ac.uk"
          class="hairline hairline-hover px-5 py-2.5 text-sm font-medium tracking-wide"
          style="color: var(--color-paper)"
        >
          Contact
        </a>
        <a
          href="https://www.linkedin.com/in/alessandro-micheli-899104114/"
          target="_blank"
          rel="noreferrer"
          aria-label="LinkedIn"
          class="hairline hairline-hover inline-flex items-center justify-center px-3 py-2.5"
          style="color: var(--color-paper)"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href="https://github.com/alemicheli"
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
          class="hairline hairline-hover inline-flex items-center justify-center px-3 py-2.5"
          style="color: var(--color-paper)"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
        <a
          href="https://scholar.google.com/citations?user=RYoj-W0AAAAJ&hl"
          target="_blank"
          rel="noreferrer"
          aria-label="Google Scholar"
          class="hairline hairline-hover inline-flex items-center justify-center px-3 py-2.5"
          style="color: var(--color-paper)"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="absolute inset-x-0 bottom-8 z-10 px-6">
    <div class="mx-auto max-w-6xl">
      <div class="rule"></div>
      <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
        <span class="coord-label">↓ scroll</span>
        <span class="coord-label">generative · probabilistic · geometric · scientific</span>
      </div>
    </div>
  </div>
</section>
