---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-white/10">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-12 md:flex-row md:items-center md:justify-between">
    <p class="text-sm text-slate-400">
      © {year} Alessandro Micheli. Built with Astro & Tailwind.
    </p>

    <div class="flex gap-5 text-sm text-slate-400">
      <a
        href="https://scholar.google.com/"
        target="_blank"
        rel="noreferrer"
        class="hover:text-white"
      >
        Google Scholar
      </a>
      <a
        href="https://github.com/alemicheli"
        target="_blank"
        rel="noreferrer"
        class="hover:text-white"
      >
        GitHub
      </a>
      <a href="mailto:hello@example.com" class="hover:text-white">Email</a>
    </div>
  </div>
</footer>
